{
  "name": "gitforge-backend",
  "version": "1.0.0",
  "description": "GitForge - Distributed Version Control & Automation Platform API",
  "main": "index.js",
  "scripts": {
    "start": "node index.js start",
    "dev": "node --watch index.js start",
    "test": "node node_modules/jest/bin/jest.js --forceExit --detectOpenHandles --runInBand",
    "test:verbose": "node node_modules/jest/bin/jest.js --forceExit --detectOpenHandles --runInBand --verbose",
    "lint": "node node_modules/eslint/bin/eslint.js ."
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "testTimeout": 30000
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.0",
    "morgan": "^1.10.1",
    "socket.io": "^4.7.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "supertest": "^7.2.2"
  }
}
