# Server
PORT=3000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/gitforge

# Auth
JWT_SECRET_KEY=your-secret-key-min-32-chars-long-here

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=15
ACCOUNT_LOCKOUT_MAX_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MS=900000

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80

# Redis (optional - falls back to in-process Map if unset/unavailable)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info
